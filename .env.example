# RIOS platform environment (copy to .env)

# --- Database ---
DATABASE_URL=postgres://rios:rios@localhost:5432/rios
# App role used for tenant-scoped queries (RLS is enforced for this role).
# Password must match migration 0008 (its strong default, or the
# RIOS_APP_DB_PASSWORD passed to the migrate step). Managed providers reject
# weak passwords — keep these two in sync and override both for a real deploy.
DATABASE_APP_URL=postgres://rios_app:Rios9Mqlym0Wq5kL3dOSM1ZE@localhost:5432/rios

# --- Server ---
PORT=4000
NODE_ENV=development
# 32+ char secret for signing access tokens (dev value; replace in every real env)
JWT_SECRET=dev-only-change-me-please-32-characters-min

# Comma-separated list of allowed CORS origins (browser → API)
CORS_ORIGINS=http://localhost:5173

# --- Web ---
VITE_API_BASE_URL=http://localhost:4000

# --- AI assistant (optional; platform is fully usable without it, per brief §12.6) ---
# ANTHROPIC_API_KEY=
RIOS_AI_MODEL=claude-opus-4-8
