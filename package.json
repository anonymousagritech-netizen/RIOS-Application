{
  "name": "rios-platform",
  "version": "0.1.0",
  "private": true,
  "description": "RIOS — Reinsurance Intelligent Operating System. A metadata-driven, multi-tenant reinsurance ERP platform.",
  "license": "UNLICENSED",
  "workspaces": [
    "packages/shared",
    "packages/domain",
    "server",
    "web"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "db:up": "docker compose up -d db",
    "db:migrate": "npm run migrate --workspace server",
    "db:seed": "npm run seed --workspace server",
    "db:reset": "npm run db:up && npm run db:migrate && npm run db:seed"
  }
}
